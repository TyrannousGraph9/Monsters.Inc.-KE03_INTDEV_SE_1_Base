@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<form class="d-flex justify-content-center mb-4" method="get">
    <div class="input-group" style="max-width: 420px; width: 100%;">
        <input type="text" name="searchString" class="form-control" placeholder="Zoeken..." />
        <div class="input-group-append">
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-search"></i>
            </button>
        </div>
    </div>
</form>


<div class="d-flex gap-4 mb-4">
    <div class="p-2 bg-light border" style="width: 300px;">
        <h2>Relevant voor jou</h2>
        <hr class="border-primary border-10 opacity-100" />
        <img class="img-fluid" src="https://smartblogger.com/wp-content/uploads/2222/12/banner-ads-mint-mobile.jpg" alt="Relevant voor jou" />
    </div>
    <div class="p-2 bg-light border" style="width: 1000px;">
        <h2>Veel gezochte categorien</h2>
        <hr class="border-primary border-10 opacity-100" />
        <table class="table">
            <thead>
                <tr>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model.Categories)
            {
                <tr>
                    <p class="h1"><a class="text-decoration-none" style="color: black;" href="">- @Html.DisplayName(p.CategoryName)</a></p>
                    <br />
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>




