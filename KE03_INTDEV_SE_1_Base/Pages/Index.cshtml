@page
@model IndexModel
@using System.Globalization
@{
    ViewData["Title"] = "Homepage";
    var euroCulture = CultureInfo.GetCultureInfo("nl-NL");
}

<form class="mb-4" method="get">
    <div class="d-flex justify-content-center mb-2 gap-2 flex-wrap">
        <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#filterOptions" aria-expanded="false" aria-controls="filterOptions">
            <i class="fa-solid fa-sliders"></i> Filters
        </button>

        <div class="input-group" style="max-width: 420px; width: 100%;">
            <input type="text" asp-for="SearchString" class="form-control" placeholder="Zoeken..." />
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-search"></i>
            </button>
        </div>
    </div>

    <div class="collapse mt-3" id="filterOptions">
        <div class="card card-body mx-auto" style="max-width: 500px;">
            <div class="form-group mb-3">
                <label class="fw-bold mb-2">Filter op categorie:</label>
                <select asp-for="FilterCategoryId" class="form-select">
                    <option value="">-- Alle categorieën --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                    }
                </select>
            </div>
            <div class="form-group mb-3">
                <label class="fw-bold mb-2">Sorteer op:</label>
                <select asp-for="SortOrder" class="form-select">
                    <option value="name_asc">Naam (A-Z)</option>
                    <option value="name_desc">Naam (Z-A)</option>
                    <option value="price_asc">Prijs (laag-hoog)</option>
                    <option value="price_desc">Prijs (hoog-laag)</option>
                </select>
            </div>
            <div class="text-end">
                <button type="submit" class="btn btn-success">Toepassen</button>
            </div>
        </div>
    </div>
</form>

<div class="d-flex gap-4 mb-5">
    <div class="p-2 bg-light border" style="width: 300px;">
        <h2>Relevant voor jou</h2>
        <hr class="border-primary border-10 opacity-100" />
        <img class="img-fluid" src="https://smartblogger.com/wp-content/uploads/2222/12/banner-ads-mint-mobile.jpg" alt="Relevant voor jou" />
    </div>
    <div class="p-2 bg-light border" style="width: 1000px;">
        <h2>Veel gezochte categorieën</h2>
        <hr class="border-primary border-10 opacity-100" />
        <table class="table">
            <tbody>
            @foreach (var cat in Model.Categories)
            {
                <tr>
                    <td class="border-0">
                        <p class="h3">
                            <a class="text-decoration-none" style="color: black;" asp-page="/Index" asp-route-FilterCategoryId="@cat.CategoryId">- @cat.CategoryName</a>
                        </p>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="text-center mb-4">
    <h2>Uitgelichte producten</h2>
    <hr class="border-primary border-10 opacity-100 mx-auto" style="max-width: 220px;" />
</div>
<div class="row g-3 justify-content-center">
    @if (Model.Products.Any())
    {
        @foreach (var p in Model.Products)
        {
            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    @{
                        string imgSrc = "";
                        if (p.Image is byte[] imgBytes)
                        {
                            imgSrc = $"data:image/png;base64,{Convert.ToBase64String(imgBytes)}";
                        }
                    }
                    <a asp-page="/Products/Details" asp-route-id="@p.Id">
                        <img src="@imgSrc" class="card-img-top" alt="Foto van @p.Name">
                    </a>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">
                            <a class="text-decoration-none text-dark" asp-page="/Products/Details" asp-route-id="@p.Id">@p.Name</a>
                        </h5>
                        <p class="card-text flex-grow-1">@p.Description</p>
                        <p class="fw-semibold mb-3">@p.Price.ToString("C", euroCulture)</p>

                        <div class="d-grid gap-2 mt-auto">
                            <a class="btn btn-outline-secondary" asp-page="/Products/Details" asp-route-id="@p.Id">Bekijk details</a>
                            <form method="post" asp-page-handler="AddToCart">
                                <input type="hidden" name="productId" value="@p.Id" />
                                <button type="submit" class="btn btn-primary w-100">Voeg toe</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center mt-4">
            <h4 class="text-muted">Geen producten gevonden die aan je zoekopdracht voldoen.</h4>
        </div>
    }
</div>
