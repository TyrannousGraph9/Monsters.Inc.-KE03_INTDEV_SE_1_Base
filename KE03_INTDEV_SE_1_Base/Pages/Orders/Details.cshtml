@page "{id:int}"
@model OrderDetailsModel
@using DataAccessLayer.Models
@using System.Globalization
@{
	ViewData["Title"] = "Order details";
	var euroCulture = CultureInfo.GetCultureInfo("nl-NL");
	var currentStepIndex = (int)Model.Status;
}

<div class="row justify-content-center">
	<div class="col-12 col-xl-10">
		<div class="bg-white border shadow-sm p-4 p-lg-5">
			<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
				<div>
					<h1 class="h3 fw-bold mb-1">Order @Model.OrderId</h1>
					<p class="text-muted mb-2">@Model.OrderDate.ToString("dd-MM-yyyy HH:mm")</p>
					<span class="badge @OrderDetailsModel.GetStatusBadgeClass(Model.Status)">@OrderDetailsModel.GetStatusLabel(Model.Status)</span>
				</div>
				<a class="btn btn-outline-dark" asp-page="/Orders">Terug naar overzicht</a>
			</div>

			<div class="border bg-light p-4 mb-4">
				<h2 class="h6 fw-bold text-uppercase text-muted mb-3">Orderstatus</h2>
				<div class="d-flex flex-wrap justify-content-between gap-3">
					@for (var i = 0; i < OrderDetailsModel.StatusSteps.Count; i++)
					{
						var step = OrderDetailsModel.StatusSteps[i];
						var isCompleted = i <= currentStepIndex;
						var isCurrent = i == currentStepIndex;
						<div class="text-center flex-fill" style="min-width: 120px;">
							<div class="rounded-circle mx-auto mb-2 d-flex align-items-center justify-content-center fw-bold @(isCompleted ? "bg-primary text-white" : "bg-white border text-muted")" style="width: 42px; height: 42px;">
								@(i + 1)
							</div>
							<div class="small @(isCurrent ? "fw-bold text-primary" : isCompleted ? "fw-semibold" : "text-muted")">@step.Label</div>
						</div>
					}
				</div>
			</div>

			<div class="border bg-light p-3 mb-4">
				<div class="row g-3">
					<div class="col-md-6">
						<div class="text-muted small text-uppercase">Naam</div>
						<div class="fw-semibold">@Model.CustomerName</div>
					</div>
					<div class="col-md-6">
						<div class="text-muted small text-uppercase">Adres</div>
						<div class="fw-semibold">@Model.CustomerAddress</div>
					</div>
				</div>
			</div>

			<div class="table-responsive mb-4">
				<table class="table align-middle">
					<thead class="table-light">
						<tr>
							<th>Product</th>
							<th class="text-center">Aantal</th>
							<th class="text-end">Prijs</th>
							<th class="text-end">Totaal</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model.Items)
						{
							<tr>
								<td>@item.Name</td>
								<td class="text-center">@item.Quantity</td>
								<td class="text-end">@item.UnitPrice.ToString("C", euroCulture)</td>
								<td class="text-end">@item.LineTotal.ToString("C", euroCulture)</td>
							</tr>
						}
					</tbody>
				</table>
			</div>

			<div class="row justify-content-end">
				<div class="col-12 col-md-5 col-lg-4">
					<div class="border bg-light p-3">
						<div class="d-flex justify-content-between mb-2">
							<span>Artikelen</span>
							<strong>@Model.TotalItems</strong>
						</div>
						<div class="d-flex justify-content-between">
							<span>Totaal prijs</span>
							<strong>@Model.TotalPrice.ToString("C", euroCulture)</strong>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>